{
  "expo": {
    "name": "Immi",
    "slug": "immi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "immi",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#070B14",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070B14"
    },
    "ios": {
      "bundleIdentifier": "com.kova.immi",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used for quick, secure sign in."
      }
    },
    "android": {
      "package": "com.kova.immi",
      "adaptiveIcon": {
        "backgroundColor": "#070B14",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Immi",
      "shortName": "Immi",
      "description": "Immi — your immigration navigator. General information, not legal advice.",
      "themeColor": "#070B14",
      "backgroundColor": "#070B14"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
